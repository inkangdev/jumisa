# ─────────────────────────────────────────────────────────────
# ai (AI 주식전망) 환경변수 템플릿
# 사용법: cp .env.example .env  후 값 채우기.
# DB는 jumisa 백엔드와 "동일한" Supabase Postgres 를 쓴다.
# 보통 레포 루트의 .env(백엔드용)에 GEMINI_API_KEY 만 추가하면 되고,
# 이 파일은 ai 컴포넌트만 따로 돌릴 때 사용한다.
# ─────────────────────────────────────────────────────────────

# === Supabase Postgres (백엔드와 동일) ===
# JDBC 형식 그대로 둬도 된다 — 코드가 jdbc: 접두어를 떼고 libpq 로 변환한다.
SUPABASE_DB_URL=jdbc:postgresql://db.<your-project-ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=<your-db-password>

# === Google Gemini (무료 등급) — https://aistudio.google.com/apikey ===
GEMINI_API_KEY=<your-gemini-api-key>

# === 선택: 모델 오버라이드 ===
# AI_MODEL=gemini-2.5-flash   # 무료. 더 좋은 무료: gemini-3-flash (가용 시)
