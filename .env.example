# ─────────────────────────────────────────────────────────────
# Jumisa 백엔드 환경변수 템플릿
# 사용법: 이 파일을 .env 로 복사한 뒤 실제 값으로 채운다.
#   cp .env.example .env
# .env 는 git 에 커밋되지 않는다 (루트 .gitignore 에서 제외).
# ─────────────────────────────────────────────────────────────

# === Supabase Postgres ===
# Supabase 대시보드 → Project Settings → Database → Connection string (JDBC) 참고.
# host/포트는 프로젝트마다 다르며 sslmode=require 는 필수.
SUPABASE_DB_URL=jdbc:postgresql://db.<your-project-ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=<your-db-password>

# 커넥션 풀 크기 (선택, 기본 10)
DB_POOL_SIZE=10

# 서버 포트 (선택, 기본 8080)
SERVER_PORT=8080

# === 이후 단계에서 추가될 값들 (지금은 비워둬도 됨) ===
# 한국투자증권 Open API
# KIS_APP_KEY=
# KIS_APP_SECRET=
# 금융위원회 공공데이터포털
# DATA_GO_KR_SERVICE_KEY=
# FMP (미국 주식, 확정 시)
# FMP_API_KEY=
# Claude API (뉴스 감성분석)
# ANTHROPIC_API_KEY=
