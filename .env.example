# ─────────────────────────────────────────────────────────────
# Jumisa 환경변수 템플릿 (셀프호스팅 / 로컬 Postgres)
# 사용법: cp .env.example .env  후 값 채우기. .env 는 git 미커밋.
# docker compose 가 이 파일을 자동으로 읽는다.
# ─────────────────────────────────────────────────────────────

# === 로컬 Postgres (docker compose 'db' 서비스) ===
POSTGRES_DB=jumisa
POSTGRES_USER=jumisa
POSTGRES_PASSWORD=change-me-strong-password   # 필수: 강한 비밀번호
DB_POOL_SIZE=20

# === 앱 DB 접속 ===
# docker compose 는 컨테이너 내부에서 db:5432 로 자동 주입하므로 따로 안 채워도 된다.
# 아래 값은 IntelliJ 등으로 앱을 호스트에서 직접 실행할 때만 필요(localhost).
DB_URL=jdbc:postgresql://localhost:5432/jumisa
DB_USER=jumisa
DB_PASSWORD=change-me-strong-password

# === 공개 주소 (Tailscale Funnel 로 확보한 고정 주소) ===
# 최초엔 http://localhost:8088 로 두고, Funnel 주소 확보 후 교체 + 카카오 콘솔에 등록.
FRONTEND_URL=http://localhost:8088

# === 카카오 로그인 (developers.kakao.com) ===
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# === AI (Google Gemini, aistudio.google.com/apikey) ===
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-flash

# === 한국투자증권(KIS) Open API — 배치 ===
KIS_ENV=prod                 # vts=모의(초당2), prod=실전(초당20). prod 는 실전 전용 앱키 필요.
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_RATE_PER_SECOND=15

# === 금융위원회 공공데이터(data.go.kr) — 배치 재무지표 ===
DATA_GO_KR_SERVICE_KEY=
