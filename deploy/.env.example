# 셀프 호스팅(docker compose) 환경변수 견본.
# 실제 값은 레포 루트 .env 에 채운다 (git 미커밋). compose 가 루트 .env 를 자동으로 읽는다.
# ── 기존 클라우드용 변수(SUPABASE_DB_URL 등)는 그대로 두고, 아래 로컬 변수만 추가하면 된다. ──

# ── 로컬 Postgres (Supabase 대체) ────────────────────────────
POSTGRES_DB=jumisa
POSTGRES_USER=jumisa
POSTGRES_PASSWORD=change-me-strong-password   # 필수: 강한 비밀번호로 교체
DB_POOL_SIZE=10

# ── 공개 주소 (Tailscale Funnel 로 확보한 고정 주소) ─────────
# 최초엔 http://localhost:8088 로 두고, Funnel 주소 확보 후 교체 + 카카오 콘솔에 등록.
FRONTEND_URL=http://localhost:8088

# ── 카카오 로그인 (developers.kakao.com) ─────────────────────
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── AI (Google Gemini, aistudio.google.com/apikey) ──────────
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-flash

# 참고: backend/ai 컨테이너의 DB 접속(SUPABASE_DB_URL=jdbc:postgresql://db:5432/jumisa)은
#       docker-compose.yml 에서 위 POSTGRES_* 값으로 자동 구성되므로 여기서 따로 설정할 필요 없다.
